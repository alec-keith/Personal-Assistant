# === Claude API ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === iMessage via BlueBubbles (PRIMARY channel) ===
# Download BlueBubbles Server: https://bluebubbles.app
# In BlueBubbles: API & Webhooks → enable ngrok → copy the URL below
BLUEBUBBLES_SERVER_URL=https://your-id.ngrok.io
BLUEBUBBLES_PASSWORD=your_bluebubbles_server_password
BLUEBUBBLES_IMESSAGE_HANDLE=+15551234567

# === Discord (FALLBACK — active when Mac/BlueBubbles is unreachable) ===
# Create bot at: discord.com/developers → New Application → Bot → Reset Token
# Enable: Message Content Intent, Server Members Intent
# Your User ID: Discord Settings → Advanced → Developer Mode → right-click yourself → Copy ID
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_USER_ID=your_discord_user_id_here

# === Todoist ===
# Get token at: todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=your_todoist_api_token_here

# === Apple Calendar / iCloud CalDAV (for Fantastical) ===
# Fantastical syncs with iCloud — we talk to iCloud CalDAV directly
ICLOUD_USERNAME=your_apple_id_email@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx  # Generate at appleid.apple.com -> App-Specific Passwords

# === Agent Behavior ===
AGENT_NAME=Atlas
AGENT_TIMEZONE=America/New_York

# === Server (Railway sets PORT automatically — only override locally if needed) ===
# PORT=8080
