# === Claude API ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Discord ===
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_USER_ID=your_discord_user_id_here  # Your personal Discord user ID (right-click yourself -> Copy ID)

# === Todoist ===
TODOIST_API_TOKEN=your_todoist_api_token_here

# === Apple Calendar / iCloud CalDAV (for Fantastical) ===
# Fantastical syncs with iCloud — we talk to iCloud CalDAV directly
ICLOUD_USERNAME=your_apple_id_email@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx  # Generate at appleid.apple.com -> App-Specific Passwords

# === Optional: Google Calendar (if Fantastical syncs to Google instead) ===
# GOOGLE_CALENDAR_CREDENTIALS_PATH=config/google_credentials.json
# GOOGLE_CALENDAR_ID=primary

# === Memory ===
CHROMA_PERSIST_DIR=data/memory

# === Agent Behavior ===
AGENT_NAME=Atlas
AGENT_TIMEZONE=America/New_York  # Your timezone
